<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="v_base_stake">base_stake</variable>
    <variable id="v_current_stake">current_stake</variable>
    <variable id="v_multiplier">martingale_multiplier</variable>
    <variable id="v_tick_counter">tick_counter</variable>
    <variable id="v_rsi">rsi_value</variable>
  </variables>

  <!-- ============================================ -->
  <!-- TRADE DEFINITION                             -->
  <!-- ============================================ -->
  <block type="trade_definition" id="td_main" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="td_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">step_index</field>
        <field name="SYMBOL_LIST">STP100</field>
        <next>
          <block type="trade_definition_tradetype" id="td_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">callput</field>
            <field name="TRADETYPE_LIST">callput</field>
            <next>
              <block type="trade_definition_contracttype" id="td_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="td_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="td_restart" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <!-- Keep buy/sell loop alive after transient platform errors -->
                        <field name="RESTART_BUYSELL">TRUE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="td_error" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="INITIALIZATION">
      <block type="variables_set" id="init_base_stake">
        <field name="VAR" id="v_base_stake">base_stake</field>
        <value name="VALUE">
          <block type="math_number" id="init_base_stake_val"><field name="NUM">1</field></block>
        </value>
        <next>
          <block type="variables_set" id="init_current_stake">
            <field name="VAR" id="v_current_stake">current_stake</field>
            <value name="VALUE">
              <block type="variables_get" id="init_current_from_base">
                <field name="VAR" id="v_base_stake">base_stake</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="init_mult">
                <field name="VAR" id="v_multiplier">martingale_multiplier</field>
                <value name="VALUE">
                  <block type="math_number" id="init_mult_val"><field name="NUM">2.1</field></block>
                </value>
                <next>
                  <block type="variables_set" id="init_tick_counter">
                    <field name="VAR" id="v_tick_counter">tick_counter</field>
                    <value name="VALUE">
                      <block type="math_number" id="init_tick_counter_val"><field name="NUM">0</field></block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="trade_opts">
        <mutation has_first_barrier="false" has_second_barrier="false" has_prediction="false"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <field name="CURRENCY_LIST">USD</field>
        <value name="DURATION">
          <shadow type="math_number_positive" id="dur_val"><field name="NUM">5</field></shadow>
        </value>
        <value name="AMOUNT">
          <block type="variables_get" id="amt_stake"><field name="VAR" id="v_current_stake">current_stake</field></block>
        </value>
      </block>
    </statement>
  </block>

  <!-- ============================================ -->
  <!-- DURING PURCHASE                              -->
  <!-- ============================================ -->
  <block type="during_purchase" id="during_block" x="1624" y="60">
    <statement name="DURING_PURCHASE_STACK">
      <block type="controls_if" id="during_if">
        <value name="IF0">
          <block type="check_sell" id="during_sell"></block>
        </value>
      </block>
    </statement>
  </block>

  <!-- ============================================ -->
  <!-- AFTER PURCHASE                               -->
  <!-- ============================================ -->
  <block type="after_purchase" id="after_block" x="1624" y="292">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="after_if">
        <mutation else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="after_win_check"><field name="CHECK_RESULT">win</field></block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="after_win_reset">
            <field name="VAR" id="v_current_stake">current_stake</field>
            <value name="VALUE">
              <block type="variables_get" id="after_win_base"><field name="VAR" id="v_base_stake">base_stake</field></block>
            </value>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="variables_set" id="after_loss_mul">
            <field name="VAR" id="v_current_stake">current_stake</field>
            <value name="VALUE">
              <block type="math_arithmetic" id="after_loss_mult">
                <field name="OP">MULTIPLY</field>
                <value name="A">
                  <block type="variables_get" id="after_loss_stake"><field name="VAR" id="v_current_stake">current_stake</field></block>
                </value>
                <value name="B">
                  <block type="variables_get" id="after_loss_multiplier"><field name="VAR" id="v_multiplier">martingale_multiplier</field></block>
                </value>
              </block>
            </value>
          </block>
        </statement>
        <next>
          <block type="variables_set" id="after_set_cooldown">
            <field name="VAR" id="v_tick_counter">tick_counter</field>
            <value name="VALUE">
              <block type="math_number" id="after_cooldown_val"><field name="NUM">3</field></block>
            </value>
            <next>
              <block type="trade_again" id="after_again"></block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <!-- ============================================ -->
  <!-- BEFORE PURCHASE (RSI + COOLDOWN)             -->
  <!-- ============================================ -->
  <block type="before_purchase" id="before_block" deletable="false" x="0" y="1279">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="controls_if" id="cooldown_check">
        <mutation else="1"></mutation>
        <value name="IF0">
          <block type="logic_compare" id="cooldown_check_gt"><field name="OP">GT</field>
            <value name="A"><block type="variables_get" id="cooldown_get"><field name="VAR" id="v_tick_counter">tick_counter</field></block></value>
            <value name="B"><block type="math_number" id="cooldown_zero"><field name="NUM">0</field></block></value>
          </block>
        </value>
        <statement name="DO0">
          <block type="math_change" id="cooldown_decrement">
            <field name="VAR" id="v_tick_counter">tick_counter</field>
            <value name="DELTA">
              <shadow type="math_number" id="cooldown_dec_val"><field name="NUM">-1</field></shadow>
            </value>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="rsi_statement" id="set_rsi">
            <field name="VARIABLE" id="v_rsi">rsi_value</field>
            <statement name="STATEMENT">
              <block type="input_list" id="rsi_input" deletable="false" movable="false">
                <value name="INPUT_LIST">
                  <block type="ticks" id="rsi_ticks" deletable="false" movable="false"></block>
                </value>
                <next>
                  <block type="period" id="rsi_period" deletable="false" movable="false">
                    <value name="PERIOD">
                      <shadow type="math_number" id="rsi_period_val"><field name="NUM">14</field></shadow>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="controls_if" id="rsi_decision">
                <mutation elseif="1"></mutation>
                <value name="IF0">
                  <block type="logic_operation" id="rsi_call_range"><field name="OP">AND</field>
                    <value name="A">
                      <block type="logic_compare" id="rsi_call_low"><field name="OP">GT</field>
                        <value name="A"><block type="variables_get" id="rsi_call_val1"><field name="VAR" id="v_rsi">rsi_value</field></block></value>
                        <value name="B"><block type="math_number" id="rsi_call_min"><field name="NUM">55</field></block></value>
                      </block>
                    </value>
                    <value name="B">
                      <block type="logic_compare" id="rsi_call_high"><field name="OP">LT</field>
                        <value name="A"><block type="variables_get" id="rsi_call_val2"><field name="VAR" id="v_rsi">rsi_value</field></block></value>
                        <value name="B"><block type="math_number" id="rsi_call_max"><field name="NUM">70</field></block></value>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="controls_if" id="call_position_guard">
                    <value name="IF0">
                      <block type="logic_negate" id="call_not_selling">
                        <value name="BOOL">
                          <block type="check_sell" id="call_check_sell"></block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="purchase" id="buy_call"><field name="PURCHASE_LIST">CALL</field></block>
                    </statement>
                  </block>
                </statement>
                <value name="IF1">
                  <block type="logic_operation" id="rsi_put_range"><field name="OP">AND</field>
                    <value name="A">
                      <block type="logic_compare" id="rsi_put_high"><field name="OP">LT</field>
                        <value name="A"><block type="variables_get" id="rsi_put_val1"><field name="VAR" id="v_rsi">rsi_value</field></block></value>
                        <value name="B"><block type="math_number" id="rsi_put_max"><field name="NUM">45</field></block></value>
                      </block>
                    </value>
                    <value name="B">
                      <block type="logic_compare" id="rsi_put_low"><field name="OP">GT</field>
                        <value name="A"><block type="variables_get" id="rsi_put_val2"><field name="VAR" id="v_rsi">rsi_value</field></block></value>
                        <value name="B"><block type="math_number" id="rsi_put_min"><field name="NUM">30</field></block></value>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO1">
                  <block type="controls_if" id="put_position_guard">
                    <value name="IF0">
                      <block type="logic_negate" id="put_not_selling">
                        <value name="BOOL">
                          <block type="check_sell" id="put_check_sell"></block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="purchase" id="buy_put"><field name="PURCHASE_LIST">PUT</field></block>
                    </statement>
                  </block>
                </statement>
              </block>
            </next>
          </block>
        </statement>
      </block>
    </statement>
  </block>

</xml>
